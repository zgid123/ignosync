{
  "name": "ignosync",
  "version": "0.0.1",
  "description": "Create .gitignore for specific TechStacks",
  "author": "Alpha",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zgid123/ignosync.git"
  },
  "keywords": [
    "git",
    "gitignore",
    "cli",
    "tool"
  ],
  "license": "MIT",
  "bin": {
    "ignosync": "./lib/cli.cjs"
  },
  "files": [
    "lib"
  ],
  "directories": {
    "lib": "lib"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clear": "pnpm -r exec rimraf node_modules dist .turbo lib && pnpm rimraf node_modules .turbo",
    "test": "vitest run --coverage",
    "update-packages": "pnpm update -i -r --latest",
    "build": "tsdown",
    "release": "pnpm build && changeset version && changeset publish",
    "set-release": "changeset",
    "local:run": "GIT_IGNORE_DEV=true tsx src/cli.ts"
  },
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@alphacifer/biome": "^0.0.10",
    "@alphacifer/tsconfig": "^0.0.15",
    "@biomejs/biome": "^2.4.12",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-istanbul": "^4.1.4",
    "changeset": "^0.2.6",
    "lefthook": "^2.1.6",
    "msw": "^2.13.4",
    "rimraf": "^6.1.3",
    "tsdown": "^0.21.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "commander": "^14.0.3",
    "prompts": "^2.4.2",
    "tslib": "^2.8.1"
  }
}
